# Copy to .env.local and fill in. Without these the app runs in MOCK mode
# (localStorage-backed demo backend with seed data — no cloud needed).

# Supabase (région eu-west / Paris)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Signature provider: 'mock' (défaut) ou 'yousign'
VITE_SIGNATURE_PROVIDER=mock

# MODE TEST — le président peut poser le vote des autres membres.
# ⚠ Viole le vote self-only et l'art. 15 : à n'utiliser que sur des données de
# test, jamais sur une décision destinée au registre. Laisser VIDE en usage réel
# (seule la chaîne 'true' ouvre le mode). À retirer dès les comptes membres créés.
VITE_TEST_VOTES=

# Yousign (rempli seulement quand VITE_SIGNATURE_PROVIDER=yousign)
# La clé API Yousign ne doit JAMAIS être exposée côté client en production :
# passer par une Edge Function Supabase. Cette variable sert au stub de dev.
VITE_YOUSIGN_API_KEY=
VITE_YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3
