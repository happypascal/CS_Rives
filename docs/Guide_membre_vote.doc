<head>
<meta charset="utf-8">
<title>Guide du membre - Voter</title>
<!--[if gte mso 9]><xml><w:WordDocument><w:View>Print</w:View></w:WordDocument></xml><![endif]-->
<style>
@page { size: A4; margin: 1.6cm 1.8cm; }
body { font-family: "Segoe UI", Arial, sans-serif; font-size: 10.5pt; color: #1e2530; line-height: 1.35; }
h1 { font-size: 17pt; color: #1F3864; margin: 0 0 2pt 0; }
.sub { font-size: 10pt; color: #55617a; margin: 0 0 10pt 0; }
h2 { font-size: 11.5pt; color: #1F3864; margin: 11pt 0 3pt 0; border-bottom: 1px solid #d3dbe9; padding-bottom: 2pt; }
p { margin: 3pt 0; }
ul { margin: 3pt 0 3pt 0; padding-left: 18pt; }
li { margin: 1.5pt 0; }
.tag { background: #eef1f7; color: #1F3864; padding: 1pt 5pt; border-radius: 3pt; font-weight: 600; }
.url { color: #1F3864; font-weight: 600; }
.foot { margin-top: 12pt; font-size: 8.5pt; color: #8a93a6; border-top: 1px solid #d3dbe9; padding-top: 4pt; }
</style>
